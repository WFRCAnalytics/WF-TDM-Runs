{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "run_metadata.schema.json",
  "title": "Run metadata",
  "type": "object",
  "required": [
    "schema_version", "run_set_id", "scenario_id", "run_id", "status",
    "started_at", "tdm", "control_center", "framework_commit"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "run_set_id": { "type": "string" },
    "scenario_id": { "type": "string" },
    "run_id": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "running", "success", "failed"] },
    "execution_mode": {
      "type": "string",
      "enum": ["cli", "manual"],
      "description": "\"cli\" if run-scenario/run-set executed the model; \"manual\" if the model was run outside the CLI and this record was produced by import-manual-run to curate outputs after the fact."
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" },
    "framework_commit": {
      "type": "string",
      "description": "Git commit SHA of this orchestration repo itself at the time of the run."
    },
    "tdm": {
      "type": "object",
      "required": ["requested_ref", "resolved_commit", "dirty"],
      "properties": {
        "requested_ref": { "type": "string" },
        "resolved_commit": { "type": "string" },
        "resolved_tag": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "detached_head": { "type": "boolean" },
        "dirty": { "type": "boolean" }
      }
    },
    "control_center": {
      "type": "object",
      "required": ["baseline_file", "run_set_overrides", "scenario_overrides"],
      "properties": {
        "baseline_file": { "type": "string" },
        "run_set_overrides": { "type": "object" },
        "scenario_overrides": { "type": "object" },
        "rendered_path": { "type": "string" },
        "driver_script": {
          "type": "string",
          "description": "Source path of the driver script staged into the scenario folder for this run -- relative to the run_set directory if a custom driver_script was declared, or relative to the TDM submodule root (e.g. 'Scenarios/_default/_HailMary_1Subfolder.s') if the framework's default was used. Absent only for execution_mode 'manual', where no staging occurred."
        }
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "command": { "type": "array", "items": { "type": "string" } },
        "exit_code": { "type": ["integer", "null"] },
        "log_path": { "type": ["string", "null"] }
      }
    },
    "scenario_folder": { "type": "string" },
    "seeded_from": {
      "type": "object",
      "required": ["scenario_id", "run_id"],
      "description": "Identifies the prior run whose raw scenario folder was copied into this one before Control Center rendering, when this scenario declared start_from_copy. Absent when the scenario started from an empty folder.",
      "properties": {
        "scenario_id": { "type": "string" },
        "run_id": { "type": "string" }
      }
    },
    "outputs": {
      "type": "object",
      "properties": {
        "inventory_count": { "type": "integer" },
        "inventory_total_bytes": { "type": "integer" },
        "curated": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "relative_path": { "type": "string" },
              "size_bytes": { "type": "integer" },
              "sha256": { "type": "string" },
              "repo_path": { "type": "string" }
            }
          }
        },
        "retired": {
          "type": "boolean",
          "description": "True once `tdmruns purge-run-set-outputs` has deleted this run's curated output files. The curated[] manifest (paths/sizes/checksums) is left in place as a permanent record of what once existed; repo_path no longer resolves to a file on disk."
        },
        "retired_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When this run's outputs were purged, if ever."
        }
      }
    },
    "error": { "type": ["string", "null"] }
  }
}
