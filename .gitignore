# Machine-specific config -- copy config/local.example.yaml to create this.
config/local.yaml

# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.venv/

# Quarto build output (published via CI, not committed)
reports/_site/
reports/.quarto/

# _dev/ presentation source is committed; rendered output is not (render on demand)
_dev/*.html
_dev/.quarto/

# Regenerated by reports/generate_title_metadata.py on every render (project pre-render hook)
reports/run_sets/*/_title_metadata.yml

# Editors / OS
.DS_Store
